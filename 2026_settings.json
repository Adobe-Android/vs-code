{
    // Restrict allowed publishers for better security.
    "extensions.allowed": {
        "microsoft": true,
        "github": true,
        "oracle": true,
        "redhat": true,
        "vmware": true,
        "SonarSource": true,
        "eamodio.gitlens": true,
        "RooVeterinaryInc.roo-cline": true,
        "DavidAnson.vscode-markdownlint": true
    },
    "redhat.telemetry.enabled": false,
    "workbench.colorTheme": "Dark Modern",
    "roo-cline.debug": false,
    "roo-cline.allowedCommands": [
        "git log",
        "git diff",
        "git show"
    ],
    "roo-cline.deniedCommands": [],
}
